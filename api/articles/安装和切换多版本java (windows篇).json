t@ubuntu:...","link":"","photos":[],"count_time":{"symbolsCount":"4.8k","symbolsTime":"4 mins."},"categories":[{"name":"linux","slug":"linux","count":6,"path":"api/categories/linux.json"}],"tags":[{"name":"chroot","slug":"chroot","count":2,"path":"api/tags/chroot.json"},{"name":"arm64","slug":"arm64","count":5,"path":"api/tags/arm64.json"},{"name":"linux Deploy","slug":"linux-Deploy","count":2,"path":"api/tags/linux-Deploy.json"}],"author":{"name":"ienAの博客","slug":"blog-author","avatar":"https://aienh.github.io/images/20230401000222.jpg","link":"/","description":"致力于分享自己学习笔记的萌新博主","socials":{"github":"https://github.com/AienH","twitter":"","stackoverflow":"","wechat":"","qq":"","weibo":"","zhihu":"","csdn":"","juejin":"","customs":{"qq":{"icon":"/svg/qq.svg","link":"https://user.qzone.qq.com/2313406889"}}}}},"next_post":{"title":"安装和切换多版本java (linux篇)","uid":"9af65ecb6fe0c8636d1b1801f0b3fd9a","slug":"安装和切换多版本java (linux篇)","date":"2023-04-10T05:00:27.000Z","updated":"2023-05-17T13:28:05.938Z","comments":true,"path":"api/articles/安装和切换多版本java (linux篇).json","keywords":null,"cover":"/medias/1668057369274.png","text":"前言一、JDK是什么？ 1、JDK : Java Development ToolKit(Java开发工具包)。JDK是整个JAVA的核心，包括了Java运行环境（Java Runtime Envirnment），一堆Java工具（javac&#x2F;java&#x2F;jdb...","link":"","photos":[],"count_time":{"symbolsCount":"16k","symbolsTime":"14 mins."},"categories":[{"name":"linux","slug":"linux","count":6,"path":"api/categories/linux.json"}],"tags":[{"name":"工具","slug":"工具","count":6,"path":"api/tags/工具.json"},{"name":"环境","slug":"环境","count":2,"path":"api/tags/环境.json"}],"author":{"name":"ienAの博客","slug":"blog-author","avatar":"https://aienh.github.io/images/20230401000222.jpg","link":"/","description":"致力于分享自己学习笔记的萌新博主","socials":{"github":"https://github.com/AienH","twitter":"","stackoverflow":"","wechat":"","qq":"","weibo":"","zhihu":"","csdn":"","juejin":"","customs":{"qq":{"icon":"/svg/qq.svg","link":"https://user.qzone.qq.com/2313406889"}}}}}}